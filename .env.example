# ═══════════════════════════════════════════════
#  Machy - Variables de Entorno
# ═══════════════════════════════════════════════

# ─── LOCAL: Docker Compose ─────────────────────
# Usado por machy-api dentro de la red Docker
DATABASE_URL=postgresql://machy:machy_dev@machy-db:5432/machy_db
JWT_SECRET=machy_jwt_dev_secret
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── LOCAL: Desarrollo sin Docker ──────────────
# Para correr backend local (npm run dev), usa:
# DATABASE_URL=postgresql://machy:machy_dev@localhost:5432/machy_db

# ─── PRODUCCIÓN: Render ────────────────────────
# Render configura estas variables automáticamente via render.yaml:
# DATABASE_URL → conexión a PostgreSQL de Render o Supabase
# JWT_SECRET  → configurar manualmente en el dashboard de Render
# CORS_ORIGIN → https://TU_DOMINIO.vercel.app

# ─── PRODUCCIÓN: Supabase ──────────────────────
# Si usas Supabase como DB en producción:
# DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# ─── Email (Nodemailer) ────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@machy.pe

# ─── Frontend ──────────────────────────────────
VITE_API_URL=http://localhost:3000/api
